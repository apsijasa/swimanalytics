---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { APP_LINKS } from '../lib/links';
---

<BaseLayout
  title="404 — Página no encontrada | SwimAnalytics"
  description="La página que buscas no existe. Regresa al inicio o accede a la plataforma."
>
  <Header />
  <main class="min-h-screen flex items-center justify-center pt-16 pb-16 bg-gray-very-light">
    <div class="text-center">
      <div class="text-8xl mb-6">🏊</div>
      <h1 class="font-heading font-bold text-black text-4xl mb-4">404</h1>
      <p class="text-gray-mid text-xl mb-8">Esta página se fue a nadar...</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-primary">Volver al inicio</a>
        <a href={APP_LINKS.login} class="btn-secondary">Ir a la plataforma</a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
