---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import ParaQuien from '../components/sections/ParaQuien.astro';
import Herramientas from '../components/sections/Herramientas.astro';
import ComoFunciona from '../components/sections/ComoFunciona.astro';
import Metricas from '../components/sections/Metricas.astro';
import Testimonios from '../components/sections/Testimonios.astro';
import BlogPreview from '../components/sections/BlogPreview.astro';
import CTAFinal from '../components/sections/CTAFinal.astro';
---

<BaseLayout
  title="SwimAnalytics — Gestiona, analiza y mejora tu club de natación"
  description="Plataforma integral de análisis y gestión para natación competitiva. Herramientas para entrenadores, administradores, nadadores y dirigentes."
>
  <Header lang="es" />
  <main>
    <Hero lang="es" />
    <ParaQuien lang="es" />
    <Herramientas lang="es" />
    <ComoFunciona lang="es" />
    <Metricas lang="es" />
    <Testimonios lang="es" />
    <BlogPreview />
    <CTAFinal lang="es" />
  </main>
  <Footer lang="es" />
</BaseLayout>
