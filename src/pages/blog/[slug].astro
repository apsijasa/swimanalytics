---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { APP_LINKS } from '../../lib/links';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout
  title={`${post.data.title} — SwimAnalytics Blog`}
  description={post.data.description}
  ogImage={post.data.heroImage}
>
  <Header />
  <main class="pt-24">
    <!-- Article header -->
    <div class="bg-black text-white py-16">
      <div class="container-content max-w-3xl">
        <span class="text-primary font-body font-semibold text-sm uppercase tracking-widest">
          {post.data.category}
        </span>
        <h1 class="font-heading font-bold text-white text-3xl sm:text-4xl mt-3 mb-4 leading-tight">
          {post.data.title}
        </h1>
        <p class="text-white/70 text-lg">{post.data.description}</p>
        <p class="text-white/40 text-sm mt-4">
          {post.data.pubDate.toLocaleDateString('es-CL', { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
      </div>
    </div>

    <!-- Hero image -->
    {post.data.heroImage && (
      <div class="w-full max-w-3xl mx-auto -mt-8 px-4 sm:px-6 lg:px-8">
        <img src={post.data.heroImage} alt={post.data.title} class="w-full rounded-2xl shadow-lg" />
      </div>
    )}

    <!-- Content -->
    <article class="container-content max-w-3xl py-12">
      <div class="prose prose-lg max-w-none prose-headings:font-heading prose-headings:text-black prose-p:text-gray-dark prose-a:text-primary prose-strong:text-black">
        <Content />
      </div>
    </article>

    <!-- CTA -->
    <div class="bg-gray-light py-12">
      <div class="container-content max-w-3xl text-center">
        <h2 class="font-heading font-bold text-black text-2xl mb-3">
          ¿Listo para llevar tu club al siguiente nivel?
        </h2>
        <p class="text-gray-mid mb-6">
          Comienza a usar SwimAnalytics hoy — es gratis.
        </p>
        <a href={APP_LINKS.login} class="btn-primary">
          Ingresar a la plataforma
        </a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
