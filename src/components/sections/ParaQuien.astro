---
import PerfilCard from '../ui/PerfilCard.astro';
import { t, type Lang } from '../../lib/i18n';

interface Props { lang?: Lang }
const { lang = 'es' } = Astro.props;
const tr = t(lang).paraQuien;

const icons = ['🏊', '🏢', '💼', '🥇', '👨‍👩‍👧', '🏆'];
---

<section id="para-quien" class="section-padding bg-gray-very-light">
  <div class="container-content">
    <div class="text-center mb-12">
      <span class="text-primary font-body font-semibold text-sm uppercase tracking-widest">{tr.tag}</span>
      <h2 class="font-heading font-bold text-black text-3xl sm:text-4xl mt-2 mb-4">{tr.title}</h2>
      <p class="text-gray-mid text-lg max-w-2xl mx-auto">{tr.subtitle}</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {tr.perfiles.map((perfil, i) => (
        <PerfilCard icon={icons[i]!} titulo={perfil.titulo} beneficios={[...perfil.beneficios]} />
      ))}
    </div>
  </div>
</section>
