---
import HerramientaCard from '../ui/HerramientaCard.astro';
import { t, type Lang } from '../../lib/i18n';

interface Props { lang?: Lang }
const { lang = 'es' } = Astro.props;
const tr = t(lang).herramientas;

const icons = ['🏗️', '📋', '📊', '🧮', '📅'];
---

<section id="herramientas" class="section-padding bg-white">
  <div class="container-content">
    <div class="text-center mb-12">
      <span class="text-primary font-body font-semibold text-sm uppercase tracking-widest">{tr.tag}</span>
      <h2 class="font-heading font-bold text-black text-3xl sm:text-4xl mt-2 mb-4">{tr.title}</h2>
      <p class="text-gray-mid text-lg max-w-2xl mx-auto">{tr.subtitle}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {tr.items.map((h, i) => (
        <HerramientaCard
          numero={i + 1}
          icon={icons[i]!}
          nombre={h.nombre}
          descripcion={h.descripcion}
          features={[...h.features]}
        />
      ))}
    </div>
  </div>
</section>
