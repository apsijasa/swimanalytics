---
import { APP_LINKS } from '../../lib/links';
import { t, type Lang } from '../../lib/i18n';

interface Props { lang?: Lang }
const { lang = 'es' } = Astro.props;
const tr = t(lang).comoFunciona;

const icons = ['🏗️', '📝', '📊', '🚀'];
---

<section id="como-funciona" class="section-padding bg-gray-light">
  <div class="container-content">
    <div class="text-center mb-12">
      <span class="text-primary font-body font-semibold text-sm uppercase tracking-widest">{tr.tag}</span>
      <h2 class="font-heading font-bold text-black text-3xl sm:text-4xl mt-2 mb-4">{tr.title}</h2>
      <p class="text-gray-mid text-lg max-w-2xl mx-auto">{tr.subtitle}</p>
    </div>

    <!-- Desktop -->
    <div class="hidden md:grid grid-cols-4 gap-4 relative mb-12">
      <div class="absolute top-8 left-[12.5%] right-[12.5%] h-0.5 bg-gray-border z-0"></div>
      {tr.pasos.map((paso, i) => (
        <div class="flex flex-col items-center text-center relative z-10">
          <div class="w-16 h-16 rounded-full bg-primary flex items-center justify-center text-2xl mb-4 shadow-lg">
            {icons[i]}
          </div>
          <span class="font-heading font-bold text-primary text-xs uppercase tracking-widest mb-1">
            {lang === 'es' ? `Paso ${i + 1}` : `Step ${i + 1}`}
          </span>
          <h3 class="font-heading font-bold text-black text-base mb-2">{paso.titulo}</h3>
          <p class="text-gray-mid text-sm leading-relaxed">{paso.descripcion}</p>
        </div>
      ))}
    </div>

    <!-- Mobile -->
    <div class="md:hidden space-y-6 mb-12">
      {tr.pasos.map((paso, i) => (
        <div class="flex gap-4 items-start">
          <div class="w-12 h-12 rounded-full bg-primary flex items-center justify-center text-xl flex-shrink-0">
            {icons[i]}
          </div>
          <div>
            <span class="text-primary font-body font-semibold text-xs uppercase tracking-widest">
              {lang === 'es' ? `Paso ${i + 1}` : `Step ${i + 1}`}
            </span>
            <h3 class="font-heading font-bold text-black text-base mt-0.5 mb-1">{paso.titulo}</h3>
            <p class="text-gray-mid text-sm leading-relaxed">{paso.descripcion}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center">
      <a href={APP_LINKS.login} class="btn-primary text-base px-8 py-4">{tr.cta}</a>
    </div>
  </div>
</section>
