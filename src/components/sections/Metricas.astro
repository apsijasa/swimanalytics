---
import { t, type Lang } from '../../lib/i18n';

interface Props { lang?: Lang }
const { lang = 'es' } = Astro.props;
const tr = t(lang).metricas;

const valores = [500, 50000, 1000000];
const sufijos = ['+', '+', '+'];
const icons = ['👥', '📋', '⏱️'];
---

<section class="section-padding bg-black">
  <div class="container-content">
    <div class="text-center mb-10">
      <h2 class="font-heading font-bold text-white text-3xl sm:text-4xl">{tr.title}</h2>
      <p class="text-white/60 text-lg mt-3">{tr.subtitle}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {tr.items.map((item, i) => (
        <div class="text-center p-8 rounded-2xl bg-white/5 border border-white/10">
          <div class="text-4xl mb-3">{icons[i]}</div>
          <p class="font-heading font-extrabold text-white text-5xl sm:text-6xl counter"
             data-target={valores[i]} data-suffix={sufijos[i]}>0</p>
          <p class="text-white/60 text-base mt-2">{item.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  function animateCounter(el: HTMLElement) {
    const target = parseInt(el.dataset.target ?? '0', 10);
    const suffix = el.dataset.suffix ?? '';
    const duration = 2000;
    const start = performance.now();

    function formatValue(n: number): string {
      if (n >= 1000000) return Math.round(n / 100000) / 10 + 'M';
      if (n >= 1000) return Math.round(n / 100) / 10 + 'k';
      return Math.round(n).toString();
    }

    function update(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = formatValue(Math.round(eased * target)) + suffix;
      if (progress < 1) requestAnimationFrame(update);
    }

    requestAnimationFrame(update);
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          animateCounter(entry.target as HTMLElement);
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.3 }
  );

  document.querySelectorAll('.counter').forEach(el => observer.observe(el));
</script>
