---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { href, variant = 'primary', size = 'md', class: className = '' } = Astro.props;

const sizeClasses = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-lg',
};

const variantClasses = {
  primary: 'bg-primary hover:bg-primary-hover text-white',
  secondary: 'border-2 border-primary text-primary hover:bg-primary-pale',
  ghost: 'text-white hover:text-white/70',
};
---

<a
  href={href}
  class={`font-body font-semibold rounded-lg transition-colors duration-200 inline-block ${sizeClasses[size]} ${variantClasses[variant]} ${className}`}
>
  <slot />
</a>
